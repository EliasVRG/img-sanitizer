{
  "name": "img-sanitizer",
  "version": "0.1.0",
  "description": "A robust Node.js library for image sanitization, validation, repair and normalization in backend pipelines.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "img-sanitizer": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:dataset": "ts-node scripts/validate-dataset.ts",
    "lint": "eslint src tests cli --ext .ts",
    "lint:fix": "eslint src tests cli --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"cli/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"cli/**/*.ts\"",
    "fixtures": "ts-node tests/fixtures/generate-fixtures.ts",
    "cli": "ts-node cli/index.ts",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "clean": "rimraf dist"
  },
  "keywords": [
    "image",
    "sanitizer",
    "validation",
    "repair",
    "base64",
    "buffer",
    "sharp",
    "backend",
    "pipeline",
    "corruption"
  ],
  "author": "Elias Victor Rocha Garcia",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "file-type": "^16.5.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.30",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "commander": "^12.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.6",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 80,
        "statements": 80
      }
    }
  }
}